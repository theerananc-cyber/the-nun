# Backend — คัดลอกเป็น .env แล้วใส่ค่าจริง
PORT=3001

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...   # service_role key (ไม่ใช่ anon key!)

# Google OAuth
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3001/api/calendar/oauth-callback

# Frontend URL (สำหรับ redirect หลัง OAuth)
FRONTEND_URL=http://localhost:5173
